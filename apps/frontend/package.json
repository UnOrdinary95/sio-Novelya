{
    "name": "@novelya/frontend",
    "private": true,
    "packageManager": "pnpm@10.32.1",
    "version": "1.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "typecheck": "tsc --noEmit",
        "lint": "eslint \"src/**/*.{ts,js}\"",
        "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
        "format": "prettier --write \"src/**/*.{ts,js,json,html,css,scss}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js,json,html,css,scss}\""
    },
    "prettier": {
        "tabWidth": 4,
        "printWidth": 100,
        "singleQuote": true,
        "overrides": [
            {
                "files": "*.html",
                "options": {
                    "parser": "angular"
                }
            }
        ]
    },
    "dependencies": {
        "@angular/cdk": "20.0.0",
        "@angular/common": "^21.0.3",
        "@angular/compiler": "^21.0.3",
        "@angular/core": "^21.0.3",
        "@angular/forms": "^21.0.3",
        "@angular/platform-browser": "^21.0.3",
        "@angular/router": "^21.0.3",
        "@ng-icons/core": ">=32.0.0 <34.0.0",
        "@ng-icons/lucide": ">=32.0.0 <34.0.0",
        "@spartan-ng/brain": "^0.0.1-alpha.570",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "ngx-sonner": ">=3.0.0",
        "rxjs": "~7.8.0",
        "tailwind-merge": "^3.3.1",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.0.1",
        "@angular/cli": "^21.0.1",
        "@angular/compiler-cli": "^21.0.3",
        "@spartan-ng/cli": "^0.0.1-alpha.570",
        "@tailwindcss/postcss": "^4.1.12",
        "jsdom": "^27.1.0",
        "postcss": "^8.5.3",
        "prettier": "^3.7.4",
        "tailwindcss": "^4.1.12",
        "tw-animate-css": "^1.4.0",
        "typescript": "~5.9.2",
        "vitest": "^4.0.8"
    }
}

{
    "editor.indentSize": 4,
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[typescript]": {
        "editor.indentSize": 4,
        "editor.tabSize": 4,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.indentSize": 4,
        "editor.tabSize": 4,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.indentSize": 4,
        "editor.tabSize": 4
    },
    "[css]": {
        "editor.indentSize": 4,
        "editor.tabSize": 4
    },
    "tailwindCSS.classFunctions": ["hlm", "cva"],
    "tailwindCSS.files.exclude": ["**/hlm-field.ts", "**/hlm-field-label.ts"],
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "docker-compose.*": "docker-compose.*, Dockerfile*",
        "package.json": "package-lock.json, pnpm-lock.yaml, pnpm-workspace.yaml, .eslint*, eslint*, .prettier*, prettier*, .editorconfig",
        "opencode.json": "AGENTS.md",
        "tsconfig.json": "tsconfig.*.json, env.d.ts, typed-router.d.ts",
        ".env": ".env.*",
        "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.js.map",
        "angular.json": ".postcssrc.json, components.json, .browserslistrc"
    }
}
